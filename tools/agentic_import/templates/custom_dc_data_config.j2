{
  "includeInputSubdirs": false,  
  "inputFiles": {
    "{{ output_filename }}": {
      {# The name of the provenance defined in the "sources" block below. Required. #}
      "provenance": "{{ provenance_name }}",

      {# Specifies that the CSV is in "variable-per-row" (long) format, which is required for explicit schemas. #}
      "format": "variablePerRow",

      {# Maps your CSV column headers to the standard Data Commons names. #}         
      "columnMappings": {{ column_mappings | tojson(indent=8) }}
    }
  },

  "groupStatVarsByProperty": true,

  {# This section defines the sources and provenances for your data. Required. #}
  "sources": {
    "{{ source_name }}": {
    "url": "{{ data_source_url }}",
      "provenances": {
        {# This name must match the "provenance" value in the "inputFiles" block above. #}
        "{{ provenance_name }}": "{{ dataset_url }}"
      }
    }
  }
}
