{
  "schema_version": "1.0",
  "rules": [
    {
      "rule_id": "check_deleted_records_percent",
      "description": "Checks that the percentage of deleted records for the entire import is within threshold.",
      "validator": "DELETED_RECORDS_PERCENT",
      "params": { "threshold": 0.1}
    },
    {
      "rule_id": "check_goldens_english",
      "description": "Validates data for english",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_english.csv",
        "input_files": "../../input0/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_math",
      "description": "Validates data for math",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_math.csv",
        "input_files": "../../input1/genmcf/summary_report.csv"
      }
    },
    {
            "rule_id": "Check_goldens_output_csv_english",
            "description": "Verifies the generated output CSV data matches established critical golden records",
            "validator": "GOLDENS_CHECK",
            "params": {
                "golden_files": "../../../../golden_data/golden_observations_english.csv",
                "input_files": "../../../../output/english.csv"
        }
    },
    {
            "rule_id": "Check_goldens_output_csv_math",
            "description": "Verifies the generated output CSV data matches established critical golden records",
            "validator": "GOLDENS_CHECK",
            "params": {
                "golden_files": "../../../../golden_data/golden_observations_math.csv",
                "input_files": "../../../../output/math.csv"
        }
    }
  ]
}