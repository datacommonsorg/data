{
  "schema_version": "1.0",
  "rules": [
    {
      "rule_id": "check_deleted_records_percent",
      "description": "Checks that the percentage of deleted points is within the threshold.",
      "validator": "DELETED_RECORDS_PERCENT",
      "params": {
        "threshold": 0.1
      }
    },
    {
      "rule_id": "check_goldens_monthly_nominal_price",
      "description": "Validates monthly nominal price data against its golden summary report.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_montly_price.csv",
        "input_files": "../../input0/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_annual_real_price",
      "description": "Validates annual real price data against its golden summary report.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_annual_real_price.csv",
        "input_files": "../../input1/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_annual_nominal_price",
      "description": "Validates annual nominal price data against its golden summary report.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_annual_nominal_price.csv",
        "input_files": "../../input2/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_monthly_indices",
      "description": "Validates monthly indices data against its golden summary report.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_montly_indices.csv",
        "input_files": "../../input3/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_annual_real_indices",
      "description": "Validates annual real indices data against its golden summary report.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_annualy_real_indices.csv",
        "input_files": "../../input4/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_annual_nominal_indices",
      "description": "Validates annual nominal indices data against its golden summary report.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_summary_report_annualy_nominal_indices.csv",
        "input_files": "../../input5/genmcf/summary_report.csv"
      }
    },
    {
      "rule_id": "check_goldens_output_commodity_monthly_price",
      "description": "Verifies that the generated commodity monthly price output CSV data matches the established golden observations.",
      "validator": "GOLDENS_CHECK",
      "params": {
        "golden_files": "../../../../golden_data/golden_observations.csv",
        "input_files": "../../../../output/commodity_monthly_price.csv"
      }
    }
  ]
}