{
    "import_specifications": [
        {
            "import_name": "WHO_TuberculosisBacteriologicallyConfirmedPercentage",
            "curator_emails": [
                "support@datacommons.org"
            ],
            "provenance_url": "https://data.who.int/indicators/i/1891124/449F55C",
            "provenance_description": "Percentage of people diagnosed with a new episode of pulmonary TB whose disease was bacteriologically confirmed",
            "scripts": [
                "download_who_tuberculosis.py",
                "../../tools/statvar_importer/stat_var_processor.py --input_data=input_files/* --pv_map=tuberculosisPercentage_pvmap.csv --config_file=tuberculosisPercentage_metadata.csv --output_path=output_files/tuberculosisPercentage_output"
            ],
            "source_files": [
                "input_files/*.csv"
            ],
            "import_inputs": [
                {
                    "template_mcf": "output_files/tuberculosisPercentage_output.tmcf",
                    "cleaned_csv": "output_files/tuberculosisPercentage_output.csv",
                    "stat_var_mcf": "output_files/tuberculosisPercentage_output_stat_vars.mcf"
                }
            ],
            "cron_schedule": "0 0 1 1,4,7,10 *"
        }
    ]
}
