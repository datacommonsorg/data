{
    "schema_version": "1.0",
    "rules": [
        {
            "rule_id": "no_deletions_for_monthly_rate",
            "validator": "SQL_VALIDATOR",
            "params": {
                "query": "SELECT * FROM differ WHERE StatVar = 'Monthly_InterestRate_FinancialInstrument_CountryCentralBankPolicyRate'",
                "condition": "DELETED = 0"
            }
        },
        {
            "rule_id": "100_deletions_for_daily_rate",
            "validator": "SQL_VALIDATOR",
            "params": {
                "query": "SELECT * FROM differ WHERE StatVar = 'Daily_InterestRate_FinancialInstrument_CountryCentralBankPolicyRate'",
                "condition": "DELETED <= 100"
            }
        },
        {
            "rule_id": "check_deleted_records_percent",
            "description": "Checks that the percentage of deleted points is within the threshold.",
            "validator": "DELETED_RECORDS_PERCENT",
            "params": {
                "threshold": 0.1
            }
        }
    ]
}
