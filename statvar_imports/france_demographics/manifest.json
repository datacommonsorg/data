{
    "import_specifications": [
        {
            "import_name": "France_Demographics",
            "curator_emails": [
                "support@datacommons.org"
            ],
            "provenance_url": "https://www.insee.fr/en/statistiques/8333211?sommaire=8333329",
            "provenance_description": "Population data for France from INSEE",
            "scripts": [
                "../../util/download_util_script.py --download_url=https://www.insee.fr/en/statistiques/fichier/8333211/Pop_annu_compo_evol_va.xlsx --output_folder=input_files/",
                "../../util/download_util_script.py --download_url=https://www.insee.fr/en/statistiques/fichier/8333211/Pop1janv_age_va.xlsx --output_folder=input_files/",
                "../../util/download_util_script.py --download_url=https://www.insee.fr/en/statistiques/fichier/8333211/Pop1janv_grages_va.xlsx --output_folder=input_files/",
                "../../util/download_util_script.py --download_url=https://www.insee.fr/en/statistiques/fichier/8333211/Pop_age_moyen_median_va.xlsx --output_folder=input_files/",
                "../../tools/statvar_importer/stat_var_processor.py --input_data='./input_files/Pop_annu_compo_evol_va.xlsx' --pv_map='annual_population_components_pvmap.csv' --config_file='france_demographics_metadata.csv' --existing_statvar_mcf=gs://unresolved_mcf/scripts/statvar/stat_vars.mcf --output_path='output/annual_population_components_output'",
                "../../tools/statvar_importer/stat_var_processor.py --input_data='./input_files/Pop1janv_age_va.xlsx' --pv_map='population_sex_detailed_age_pvmap.csv' --config_file='france_demographics_metadata.csv' --existing_statvar_mcf=gs://unresolved_mcf/scripts/statvar/stat_vars.mcf --output_path='output/population_sex_detailed_age_output'",
                "../../tools/statvar_importer/stat_var_processor.py --input_data='./input_files/Pop1janv_grages_va.xlsx' --pv_map='population_sex_age_groups_pvmap.csv' --config_file='france_demographics_metadata.csv' --existing_statvar_mcf=gs://unresolved_mcf/scripts/statvar/stat_vars.mcf --output_path='output/population_sex_age_groups_output'",
                "../../tools/statvar_importer/stat_var_processor.py --input_data='./input_files/Pop_age_moyen_median_va.xlsx' --pv_map='average_median_age_pvmap.csv' --config_file='france_demographics_metadata.csv' --existing_statvar_mcf=gs://unresolved_mcf/scripts/statvar/stat_vars.mcf --output_path='output/average_median_age_output'"
            ],
            "import_inputs": [
                {
                    "template_mcf": "output/population_sex_age_groups_output.tmcf",
                    "cleaned_csv": "output/*_output.csv"
                }
            ],
            "source_files": [
                "./input_files/*.xlsx"
            ],
            "user_script_timeout": 3600,
            "cron_schedule": "0 10 21 * *",
            "resource_limits": {
                "cpu": 16,
                "memory": 128,
                "disk": 500
            }
        }
    ]
}
