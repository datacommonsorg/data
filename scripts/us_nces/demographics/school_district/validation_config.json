{
    "schema_version": "1.0",
    "rules": [
        {
            "rule_id": "check_deleted_records_percent",
            "description": "Strictly enforce historical deletion average threshold of 0.1%",
            "validator": "DELETED_RECORDS_PERCENT",
            "params": {
                "threshold": 0.1
            }
        },
        {
            "rule_id": "check_goldens_school_summary_report",
            "description": "Validates school summary_report.csv against golden summary data",
            "validator": "GOLDENS_CHECK",
            "params": {
                "golden_files": "../../../../golden_data/district_school_golden_summary_report.csv",
                "input_files": "../../input0/genmcf/summary_report.csv"
            }
        },
        {
            "rule_id": "check_goldens_school_output_csv",
            "description": "Verifies school output CSV data matches established golden observations",
            "validator": "GOLDENS_CHECK",
            "params": {
                "golden_files": "../../../../golden_data/district_school_golden_observations.csv",
                "input_files": "../../../../gcs_folder/output_files/us_nces_demographics_district_school.csv"
            }
        },
        {
            "rule_id": "check_goldens_place_output_csv",
            "description": "Verifies place output CSV data matches established golden place records",
            "validator": "GOLDENS_CHECK",
            "params": {
                "golden_files": "../../../../golden_data/district_place_golden_observations.csv",
                "input_files": "../../../../gcs_folder/output_place/us_nces_demographics_district_place.csv"
            }
        }
    ]
}
